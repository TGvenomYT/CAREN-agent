OLLAMA_MODEL=gpt-oss:20b-cloud
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=
SENDER_EMAIL=
EMAIL_PASSWORD=
SMTP_SERVER=
SMTP_PORT=
IMAP_SERVER=

# --- Auth ---
# Password the user types to unlock the dashboard.
APP_PASSWORD=
# Random string used to sign JWTs. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# Comma-separated list of allowed frontend origins (no trailing slash).
# Example: https://<user>.github.io,http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
